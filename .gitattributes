# Repository-wide line ending enforcement (supersedes local core.autocrlf)
# - Auto-detect text vs binary files
# - Normalise text files to LF on commit and keep LF on checkout
* text=auto eol=lf

# Exclude development config and helper scripts from git archive exports
.gitattributes export-ignore
.gitignore export-ignore
clean.py export-ignore

# Exclude compiled bin/obj directories from individual mod source folders
mods/delivery-temperature-limit-supercooled/Source/bin/ export-ignore
mods/delivery-temperature-limit-supercooled/Source/obj/ export-ignore
